APP_NAME=Glodaxia
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=noticias
DB_USERNAME=noticias
DB_PASSWORD=noticias123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Cache & Session
CACHE_STORE=redis
SESSION_DRIVER=redis

# Queue
QUEUE_CONNECTION=redis

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Broadcasting
BROADCAST_DRIVER=log
REVERB_APP_KEY=noticias-platform-key
REVERB_APP_SECRET=noticias-platform-secret
REVERB_APP_ID=noticias-platform
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Filesystem
FILESYSTEM_DISK=local

# Media Storage Disk: 'public' (local) or 'r2' (Cloudflare R2)
MEDIA_DISK=public

# Cloudflare R2 (S3-compatible object storage)
# Configurar cuando se pase a producción con tráfico
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=https://{account_id}.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.{tu-dominio}.com

# Cloudflare CDN Cache Purge (opcional — para invalidar cache al eliminar/modificar imágenes)
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:8000

# Session
SESSION_LIFETIME=120

# Horizon
HORIZON_PREFIX=glodaxia_horizon:

# OpenAI
OPENAI_API_KEY=

# OpenRouter (principal)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# SiliconFlow (generación de imágenes con FLUX)
SILICONFLOW_API_KEY=
SILICONFLOW_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Jina AI (scraper)
JINA_API_KEY=

# Resend (produccion) - cambiar MAIL_MAILER=resend
MAIL_MAILER=smtp
# MAIL_MAILER=resend
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=editorial@glodaxia.com
MAIL_FROM_NAME=Glodaxia
RESEND_API_KEY=

# IndexNow (Bing/Yandex instant indexing)
INDEXNOW_KEY=
