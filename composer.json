{
    "name": "noticias/noticias-platform",
    "type": "project",
    "description": "Plataforma de noticias automatizada con IA",
    "keywords": ["laravel", "frankenphp", "news", "ai", "automation"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-gd": "*",
        "ext-pgsql": "*",
        "ext-redis": "*",
        "ext-zip": "*",
        "filament/actions": "^3.0",
        "filament/filament": "^3.3",
        "filament/forms": "^3.0",
        "filament/notifications": "^3.0",
        "filament/spatie-laravel-media-library-plugin": "^3.3",
        "filament/spatie-laravel-translatable-plugin": "^3.3",
        "filament/tables": "^3.0",
        "filament/widgets": "^3.0",
        "intervention/image": "^2.7",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.0",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10",
        "mcamara/laravel-localization": "^2.4",
        "openai-php/client": "^0.10.0",
        "simplepie/simplepie": "^1.8",
        "spatie/laravel-ignition": "^2.0",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-translatable": "^6.13",
        "vedmant/laravel-feed-reader": "^1.6"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    }
}
